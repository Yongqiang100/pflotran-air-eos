SIMULATION
  SIMULATION_TYPE SUBSURFACE
  PROCESS_MODELS
    SUBSURFACE_FLOW flow
      MODE GENERAL
      OPTIONS
      /
    /
  /
END

SUBSURFACE

EOS GAS
  DENSITY PR_PENELOUX_AIR
END

GRID
  TYPE STRUCTURED
  ORIGIN 0.d0 0.d0 0.d0
  NXYZ 1 1 1
  BOUNDS
    0.d0 0.d0 0.d0
    1.d0 1.d0 1.d0
  /
END

FLUID_PROPERTY
  DIFFUSION_COEFFICIENT 1.d-9
END

MATERIAL_PROPERTY soil
  ID 1
  CHARACTERISTIC_CURVES default
  POROSITY 0.20d0
  TORTUOSITY 1.d0
  ROCK_DENSITY 2600.d0
  THERMAL_CONDUCTIVITY_DRY 2.54d0
  THERMAL_CONDUCTIVITY_WET 2.54d0
  HEAT_CAPACITY 920.d0
  PERMEABILITY
    PERM_X 1.d-12
    PERM_Y 1.d-12
    PERM_Z 1.d-12
  /
END

CHARACTERISTIC_CURVES default
  SATURATION_FUNCTION VAN_GENUCHTEN
    ALPHA 1.d-4
    M 0.5d0
    LIQUID_RESIDUAL_SATURATION 0.1d0
  /
  PERMEABILITY_FUNCTION MUALEM_VG_LIQ
    PHASE LIQUID
    M 0.5d0
    LIQUID_RESIDUAL_SATURATION 0.1d0
  /
  PERMEABILITY_FUNCTION MUALEM_VG_GAS
    M 0.5d0
    LIQUID_RESIDUAL_SATURATION 0.1d0
    GAS_RESIDUAL_SATURATION 0.05d0
  /
END

REGION all
  COORDINATES
    0.d0 0.d0 0.d0
    1.d0 1.d0 1.d0
  /
END

FLOW_CONDITION initial_gas_state
  TYPE
    GAS_PRESSURE DIRICHLET
    GAS_SATURATION DIRICHLET
    TEMPERATURE DIRICHLET
  /
  GAS_PRESSURE 8.d6
  GAS_SATURATION 0.95d0
  TEMPERATURE 40.d0
END

INITIAL_CONDITION
  FLOW_CONDITION initial_gas_state
  REGION all
END

STRATA
  REGION all
  MATERIAL soil
END

TIME
  FINAL_TIME 1.d0 s
  INITIAL_TIMESTEP_SIZE 1.d0 s
  MAXIMUM_TIMESTEP_SIZE 1.d0 s
END

OUTPUT
  SNAPSHOT_FILE
    PERIODIC TIME 1.d0 s
    FORMAT TECPLOT POINT
  /
  VARIABLES
    GAS_DENSITY
    GAS_VISCOSITY
    GAS_PRESSURE
    GAS_SATURATION
    TEMPERATURE
    LIQUID_PRESSURE
    LIQUID_SATURATION
  /
END

END_SUBSURFACE

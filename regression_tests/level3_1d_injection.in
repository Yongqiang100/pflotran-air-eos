SIMULATION
  SIMULATION_TYPE SUBSURFACE
  PROCESS_MODELS
    SUBSURFACE_FLOW flow
      MODE GENERAL
      OPTIONS
      /
    /
  /
END

SUBSURFACE

EOS GAS
  DENSITY PR_PENELOUX_AIR
END

# 1D column: 100 m long, 1 m x 1 m cross-section, 100 cells
GRID
  TYPE STRUCTURED
  ORIGIN 0.d0 0.d0 0.d0
  NXYZ 100 1 1
  BOUNDS
    0.d0   0.d0 0.d0
    100.d0 1.d0 1.d0
  /
END

FLUID_PROPERTY
  DIFFUSION_COEFFICIENT 1.d-9
END

# Yang et al. 2024 Table 2 base case (1000 mD, 0.2 porosity)
MATERIAL_PROPERTY storage_aquifer
  ID 1
  CHARACTERISTIC_CURVES default
  POROSITY 0.20d0
  TORTUOSITY 1.d0
  ROCK_DENSITY 2600.d0
  THERMAL_CONDUCTIVITY_DRY 2.54d0
  THERMAL_CONDUCTIVITY_WET 2.54d0
  HEAT_CAPACITY 920.d0
  PERMEABILITY
    PERM_X 9.87d-13
    PERM_Y 9.87d-13
    PERM_Z 9.87d-13
  /
END

CHARACTERISTIC_CURVES default
  SATURATION_FUNCTION VAN_GENUCHTEN
    ALPHA 1.80d-4
    M 0.83d0
    LIQUID_RESIDUAL_SATURATION 0.30d0
  /
  PERMEABILITY_FUNCTION MUALEM_VG_LIQ
    PHASE LIQUID
    M 0.83d0
    LIQUID_RESIDUAL_SATURATION 0.30d0
  /
  PERMEABILITY_FUNCTION MUALEM_VG_GAS
    M 0.83d0
    LIQUID_RESIDUAL_SATURATION 0.30d0
    GAS_RESIDUAL_SATURATION 0.05d0
  /
END

REGION all
  COORDINATES
    0.d0   0.d0 0.d0
    100.d0 1.d0 1.d0
  /
END

REGION inlet
  COORDINATES
    0.d0 0.d0 0.d0
    0.d0 1.d0 1.d0
  /
  FACE WEST
END

REGION outlet
  COORDINATES
    100.d0 0.d0 0.d0
    100.d0 1.d0 1.d0
  /
  FACE EAST
END

# Initial: liquid-dominated at 80 bar (5% residual gas saturation)
FLOW_CONDITION initial_brine
  TYPE
    GAS_PRESSURE DIRICHLET
    GAS_SATURATION DIRICHLET
    TEMPERATURE DIRICHLET
  /
  GAS_PRESSURE 8.d6
  GAS_SATURATION 0.05d0
  TEMPERATURE 40.d0
END

# Inlet: gas-dominated at 85 bar (5 bar driving pressure)
FLOW_CONDITION gas_inlet
  TYPE
    GAS_PRESSURE DIRICHLET
    GAS_SATURATION DIRICHLET
    TEMPERATURE DIRICHLET
  /
  GAS_PRESSURE 8.5d6
  GAS_SATURATION 0.95d0
  TEMPERATURE 40.d0
END

# Outlet: held at initial state (Dirichlet sink)
FLOW_CONDITION fixed_outlet
  TYPE
    GAS_PRESSURE DIRICHLET
    GAS_SATURATION DIRICHLET
    TEMPERATURE DIRICHLET
  /
  GAS_PRESSURE 8.d6
  GAS_SATURATION 0.05d0
  TEMPERATURE 40.d0
END

INITIAL_CONDITION
  FLOW_CONDITION initial_brine
  REGION all
END

BOUNDARY_CONDITION inlet_BC
  FLOW_CONDITION gas_inlet
  REGION inlet
END

BOUNDARY_CONDITION outlet_BC
  FLOW_CONDITION fixed_outlet
  REGION outlet
END

STRATA
  REGION all
  MATERIAL storage_aquifer
END

# 1 hour simulation
TIME
  FINAL_TIME 3600.d0 s
  INITIAL_TIMESTEP_SIZE 1.d0 s
  MAXIMUM_TIMESTEP_SIZE 60.d0 s
END

OUTPUT
  SNAPSHOT_FILE
    TIMES s 0.d0 60.d0 600.d0 1800.d0 3600.d0
    FORMAT TECPLOT POINT
  /
  VARIABLES
    GAS_DENSITY
    GAS_VISCOSITY
    GAS_PRESSURE
    GAS_SATURATION
    TEMPERATURE
    LIQUID_PRESSURE
    LIQUID_SATURATION
  /
END

END_SUBSURFACE
